NEXT_PUBLIC_SITE_URL=https://flamingfoodies.com
NEXT_PUBLIC_SITE_NAME=FlamingFoodies
ALLOW_SAMPLE_FALLBACKS=true

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Legacy Supabase key names are still supported if needed.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

CONVERTKIT_API_KEY=
CONVERTKIT_API_SECRET=
CONVERTKIT_FORM_ID=

NEXT_PUBLIC_AMAZON_TAG=flamingfoodies-20

NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_SHOW_ADS=false
NEXT_PUBLIC_ADSENSE_BLOG_INLINE_SLOT=
NEXT_PUBLIC_ADSENSE_BLOG_ARCHIVE_SLOT=
NEXT_PUBLIC_ADSENSE_REVIEW_INLINE_SLOT=
NEXT_PUBLIC_ADSENSE_REVIEW_ARCHIVE_SLOT=
ADS_TXT_EXTRA_LINES=

KV_REST_API_URL=
KV_REST_API_TOKEN=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CRON_SECRET=

UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_IDS=instagram:profile-id,pinterest:profile-id,facebook:profile-id

# Google Search Console API
# Recommended first auth path: OAuth client + refresh token for a Google account
# that already has access to the Search Console property.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_SEARCH_CONSOLE_PROPERTY=sc-domain:flamingfoodies.com
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=
GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=

NEXT_PUBLIC_SKIMLINKS_ID=
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_ALLOW_MOCK_ADMIN=true
